{
  "_comment": "Navy configuration. All paths are relative to the Navy directory unless absolute.",

  "server": {
    "_comment": "MCP server / tool settings",

    "command_timeout": 120,
    "max_command_timeout": 1800,

    "port_scan_timeout": 2,
    "port_scan_max_ports": 500,
    "port_scan_default_ports": "80,443,8080,22,21,25,3306,1433,3389,445,8443,8888,9200,6379,27017,5432,23,110,143,53",

    "fetch_url_timeout": 15,
